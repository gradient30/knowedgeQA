# Copy this file to .env.prod and replace every placeholder before deployment.

APP_NAME=QA Knowledge Platform
DEBUG=false
VERSION=1.0.0

FRONTEND_ORIGIN=https://qa.example.com
PUBLIC_API_URL=https://api.qa.example.com
ALLOWED_HOSTS=["https://qa.example.com"]

POSTGRES_DB=qa_platform
POSTGRES_USER=qa_user
POSTGRES_PASSWORD=replace-with-strong-postgres-password

REDIS_PASSWORD=replace-with-strong-redis-password

SECRET_KEY=replace-with-at-least-32-random-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=[".jpg",".jpeg",".png",".gif",".pdf",".doc",".docx",".txt",".md",".zip"]

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASSWORD=replace-with-smtp-password
SMTP_TLS=true
ENABLE_EMAIL_QUEUE=true
